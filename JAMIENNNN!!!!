local Library = {}
local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")
local LocalPlayer = game:GetService("Players").LocalPlayer

local Themes = {
    ["default"] = Color3.fromRGB(15, 15, 15),
    ["blue"] = Color3.fromRGB(15, 25, 45),
    ["red"] = Color3.fromRGB(35, 10, 10),
    ["purple"] = Color3.fromRGB(25, 10, 40),
    ["amethyst"] = Color3.fromRGB(45, 10, 70)
}

function Library:CreateWindow(options)
    local WindowName = options.Name or "SGX UI"
    local ThemeColor = Themes[options.Theme or "default"] or Themes["default"]
    
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SGX_Classic_V14"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Parent = game.CoreGui or LocalPlayer:WaitForChild("PlayerGui")
    
    -- INTRO LABEL
    local Intro = Instance.new("TextLabel")
    Intro.Size = UDim2.new(0, 500, 0, 50)
    Intro.Position = UDim2.new(0.5, -800, 0.5, -25) -- Start off-left
    Intro.BackgroundTransparency = 1
    Intro.Text = WindowName
    Intro.TextColor3 = Color3.fromRGB(255, 255, 255)
    Intro.Font = Enum.Font.GothamBold
    Intro.TextSize = 28
    Intro.Parent = ScreenGui

    -- MAIN FRAME (Classic Look)
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 520, 0, 0) -- Dropdown start
    MainFrame.Position = UDim2.new(0.5, -260, 0.5, -170)
    MainFrame.BackgroundColor3 = ThemeColor
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Visible = false
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

    -- DRAGGING LOGIC (Fixed)
    local function MakeDraggable(frame)
        local dragging, dragInput, dragStart, startPos
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = frame.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        UIS.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end
    MakeDraggable(MainFrame)

    -- SIDEBAR (Left)
    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 140, 1, -50)
    Sidebar.Position = UDim2.new(0, 10, 0, 45)
    Sidebar.BackgroundTransparency = 1
    Sidebar.Parent = MainFrame
    Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 5)

    -- CONTAINER
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -165, 1, -60)
    Container.Position = UDim2.new(0, 155, 0, 50)
    Container.BackgroundTransparency = 1
    Container.Parent = MainFrame

    -- ANIMATION SEQUENCE
    task.spawn(function()
        -- 1. Slide In
        TS:Create(Intro, TweenInfo.new(1, Enum.EasingStyle.Quart), {Position = UDim2.new(0.5, -250, 0.5, -25)}):Play()
        task.wait(1.2)
        
        -- 2. Animated Spacing (E X A M P L E)
        local originalText = WindowName
        for i = 1, 10 do -- Smoothly "stretch" the text
            local spaced = ""
            for char in originalText:gmatch(".") do
                spaced = spaced .. char .. string.rep(" ", i/2)
            end
            Intro.Text = spaced
            task.wait(0.05)
        end
        task.wait(0.8)

        -- 3. Dropdown UI
        TS:Create(Intro, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        MainFrame.Visible = true
        TS:Create(MainFrame, TweenInfo.new(0.8, Enum.EasingStyle.Back), {Size = UDim2.new(0, 520, 0, 340)}):Play()
    end)

    local Window = { CurrentTab = nil }

    -- TOGGLE UI BUTTON
    function Window:CreateToggleUI(cfg)
        local TBtn = Instance.new("TextButton")
        TBtn.Size = UDim2.new(0, 50, 0, 50)
        TBtn.Position = UDim2.new(0.05, 0, 0.4, 0)
        TBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        TBtn.Text = cfg.name or ""
        TBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        TBtn.Font = Enum.Font.GothamBold
        TBtn.Parent = ScreenGui
        Instance.new("UICorner", TBtn).CornerRadius = UDim.new(1, 0)
        MakeDraggable(TBtn)

        if cfg.image and cfg.image ~= "" then
            local img = Instance.new("ImageLabel")
            img.Size = UDim2.new(0.6, 0, 0.6, 0)
            img.Position = UDim2.new(0.2, 0, 0.2, 0)
            img.Image = cfg.image
            img.BackgroundTransparency = 1
            img.Parent = TBtn
        end

        TBtn.MouseButton1Click:Connect(function()
            MainFrame.Visible = not MainFrame.Visible
        end)
    end

    function Window:CreateTab(name)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 32)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = "  " .. name
        TabBtn.TextColor3 = Color3.fromRGB(140, 140, 140)
        TabBtn.Font = Enum.Font.Gotham
        TabBtn.TextXAlignment = Enum.TextXAlignment.Left
        TabBtn.Parent = Sidebar

        local Page = Instance.new("ScrollingFrame")
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Page.Parent = Container
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)

        if not Window.CurrentTab then
            Window.CurrentTab = Page
            Page.Visible = true
            TabBtn.TextColor3 = Color3.fromRGB(160, 100, 255)
        end

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Color3.fromRGB(140, 140, 140) end end
            Page.Visible = true
            TabBtn.TextColor3 = Color3.fromRGB(160, 100, 255)
        end)

        local Elements = {}

        function Elements:CreateToggle(tname, cb)
            local T = Instance.new("TextButton")
            T.Size = UDim2.new(1, -10, 0, 40)
            T.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            T.Text = "     " .. tname
            T.TextColor3 = Color3.fromRGB(230, 230, 230)
            T.Font = Enum.Font.Gotham
            T.TextXAlignment = Enum.TextXAlignment.Left
            T.Parent = Page
            Instance.new("UICorner", T).CornerRadius = UDim.new(0, 6)

            local Track = Instance.new("Frame")
            Track.Size = UDim2.new(0, 36, 0, 20)
            Track.Position = UDim2.new(1, -46, 0.5, -10)
            Track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Track.Parent = T
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Circle = Instance.new("Frame")
            Circle.Size = UDim2.new(0, 14, 0, 14)
            Circle.Position = UDim2.new(0, 3, 0.5, -7)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Circle.Parent = Track
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            local s = false
            T.MouseButton1Click:Connect(function()
                s = not s
                TS:Create(Track, TweenInfo.new(0.2), {BackgroundColor3 = s and Color3.fromRGB(160, 100, 255) or Color3.fromRGB(40, 40, 40)}):Play()
                TS:Create(Circle, TweenInfo.new(0.2), {Position = s and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)}):Play()
                cb(s)
            end)
        end

        function Elements:CreateButton(bname, cb)
            local B = Instance.new("TextButton")
            B.Size = UDim2.new(1, -10, 0, 40)
            B.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            B.Text = "     " .. bname
            B.TextColor3 = Color3.fromRGB(230, 230, 230)
            B.Font = Enum.Font.Gotham
            B.TextXAlignment = Enum.TextXAlignment.Left
            B.Parent = Page
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 6)
            B.MouseButton1Click:Connect(cb)
        end

        function Elements:CreateSlider(sname, min, max, cb)
            local SFrame = Instance.new("Frame")
            SFrame.Size = UDim2.new(1, -10, 0, 50)
            SFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            SFrame.Parent = Page
            Instance.new("UICorner", SFrame).CornerRadius = UDim.new(0, 6)

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, -20, 0, 20)
            Label.Position = UDim2.new(0, 15, 0, 5)
            Label.BackgroundTransparency = 1
            Label.Text = sname .. " : " .. min
            Label.TextColor3 = Color3.fromRGB(200, 200, 200)
            Label.Font = Enum.Font.Gotham
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = SFrame

            local Bar = Instance.new("Frame")
            Bar.Size = UDim2.new(1, -30, 0, 6)
            Bar.Position = UDim2.new(0, 15, 1, -15)
            Bar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            Bar.Parent = SFrame
            Instance.new("UICorner", Bar)

            local Fill = Instance.new("Frame")
            Fill.Size = UDim2.new(0, 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(160, 100, 255)
            Fill.Parent = Bar
            Instance.new("UICorner", Fill)

            local dragging = false
            local function Update()
                local move = math.clamp((UIS:GetMouseLocation().X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                Fill.Size = UDim2.new(move, 0, 1, 0)
                local val = math.floor(min + ((max - min) * move))
                Label.Text = sname .. " : " .. val
                cb(val)
            end

            SFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true Update()
                end
            end)
            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
            end)
            UIS.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then Update() end
            end)
        end

        return Elements
    end

    return Window
end

return Library
