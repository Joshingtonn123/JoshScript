local UI = {}

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

function UI:CreateWindow(title)

local gui = Instance.new("ScreenGui",game.CoreGui)
gui.Name = "CS_UI"

local main = Instance.new("Frame",gui)
main.Size = UDim2.new(0,650,0,420)
main.Position = UDim2.new(0.5,-325,0.5,-210)
main.BackgroundColor3 = Color3.fromRGB(24,24,24)
main.BorderColor3 = Color3.fromRGB(60,60,60)

local top = Instance.new("Frame",main)
top.Size = UDim2.new(1,0,0,28)
top.BackgroundColor3 = Color3.fromRGB(18,18,18)

local titleLabel = Instance.new("TextLabel",top)
titleLabel.Size = UDim2.new(1,0,1,0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = title
titleLabel.Font = Enum.Font.Code
titleLabel.TextColor3 = Color3.new(1,1,1)
titleLabel.TextSize = 16

local sidebar = Instance.new("Frame",main)
sidebar.Size = UDim2.new(0,140,1,-28)
sidebar.Position = UDim2.new(0,0,0,28)
sidebar.BackgroundColor3 = Color3.fromRGB(30,30,30)

local container = Instance.new("Frame",main)
container.Size = UDim2.new(1,-140,1,-28)
container.Position = UDim2.new(0,140,0,28)
container.BackgroundTransparency = 1

local tabLayout = Instance.new("UIListLayout",sidebar)
tabLayout.SortOrder = Enum.SortOrder.LayoutOrder

local pages = {}

local window = {}

function window:CreateTab(name)

local button = Instance.new("TextButton",sidebar)
button.Size = UDim2.new(1,0,0,32)
button.BackgroundColor3 = Color3.fromRGB(35,35,35)
button.TextColor3 = Color3.new(1,1,1)
button.Text = name
button.Font = Enum.Font.Code
button.TextSize = 14

local page = Instance.new("Frame",container)
page.Size = UDim2.new(1,0,1,0)
page.BackgroundTransparency = 1
page.Visible = false

local layout = Instance.new("UIListLayout",page)
layout.Padding = UDim.new(0,8)

pages[name] = page

button.MouseButton1Click:Connect(function()
for _,p in pairs(pages) do
p.Visible=false
end
page.Visible=true
end)

local tab = {}

function tab:Section(text)

local frame = Instance.new("Frame",page)
frame.Size = UDim2.new(1,-20,0,120)
frame.BackgroundColor3 = Color3.fromRGB(35,35,35)

local label = Instance.new("TextLabel",frame)
label.Size = UDim2.new(1,0,0,18)
label.BackgroundTransparency = 1
label.Text = text
label.TextColor3 = Color3.new(1,1,1)
label.Font = Enum.Font.Code
label.TextSize = 14

local secLayout = Instance.new("UIListLayout",frame)
secLayout.Padding = UDim.new(0,6)

local section = {}

function section:Toggle(text,callback)

local btn = Instance.new("TextButton",frame)
btn.Size = UDim2.new(1,-10,0,24)
btn.BackgroundColor3 = Color3.fromRGB(45,45,45)
btn.Text = text.." [OFF]"
btn.Font = Enum.Font.Code
btn.TextColor3 = Color3.new(1,1,1)

local state=false

btn.MouseButton1Click:Connect(function()
state=not state
btn.Text=text.." ["..(state and "ON" or "OFF").."]"
callback(state)
end)

end

function section:Button(text,callback)

local btn = Instance.new("TextButton",frame)
btn.Size = UDim2.new(1,-10,0,24)
btn.BackgroundColor3 = Color3.fromRGB(45,45,45)
btn.Text = text
btn.Font = Enum.Font.Code
btn.TextColor3 = Color3.new(1,1,1)

btn.MouseButton1Click:Connect(callback)

end

function section:Slider(text,min,max,default,callback)

local holder = Instance.new("Frame",frame)
holder.Size = UDim2.new(1,-10,0,34)
holder.BackgroundTransparency=1

local label = Instance.new("TextLabel",holder)
label.Size = UDim2.new(1,0,0,16)
label.BackgroundTransparency=1
label.Text=text..": "..default
label.Font=Enum.Font.Code
label.TextColor3=Color3.new(1,1,1)
label.TextSize=14

local bar = Instance.new("Frame",holder)
bar.Size=UDim2.new(1,0,0,6)
bar.Position=UDim2.new(0,0,0,20)
bar.BackgroundColor3=Color3.fromRGB(60,60,60)

local fill = Instance.new("Frame",bar)
fill.Size=UDim2.new((default-min)/(max-min),0,1,0)
fill.BackgroundColor3=Color3.fromRGB(0,170,255)

bar.InputBegan:Connect(function(input)
if input.UserInputType==Enum.UserInputType.MouseButton1 then

local move
move=UIS.InputChanged:Connect(function(i)

if i.UserInputType==Enum.UserInputType.MouseMovement then

local percent=math.clamp(
(Mouse.X-bar.AbsolutePosition.X)/bar.AbsoluteSize.X,
0,1
)

fill.Size=UDim2.new(percent,0,1,0)

local value=math.floor(min+(max-min)*percent)
label.Text=text..": "..value

callback(value)

end
end)

UIS.InputEnded:Connect(function(i)
if i.UserInputType==Enum.UserInputType.MouseButton1 then
move:Disconnect()
end
end)

end
end)

end

function section:Dropdown(text,options,callback)

local btn = Instance.new("TextButton",frame)
btn.Size=UDim2.new(1,-10,0,24)
btn.BackgroundColor3=Color3.fromRGB(45,45,45)
btn.Text=text.." ▼"
btn.Font=Enum.Font.Code
btn.TextColor3=Color3.new(1,1,1)

btn.MouseButton1Click:Connect(function()
local choice = options[math.random(1,#options)]
btn.Text=text..": "..choice
callback(choice)
end)

end

function section:Keybind(text,callback)

local btn=Instance.new("TextButton",frame)
btn.Size=UDim2.new(1,-10,0,24)
btn.BackgroundColor3=Color3.fromRGB(45,45,45)
btn.Text=text.." [NONE]"
btn.Font=Enum.Font.Code
btn.TextColor3=Color3.new(1,1,1)

btn.MouseButton1Click:Connect(function()

btn.Text=text.." [...]"

local conn
conn=UIS.InputBegan:Connect(function(key,gp)

if not gp then
btn.Text=text.." ["..key.KeyCode.Name.."]"
callback(key.KeyCode)
conn:Disconnect()
end

end)

end)

end

return section
end

return tab
end

return window
end

return UI
