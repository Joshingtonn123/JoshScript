local Library = {}
local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")

function Library:CreateWindow(options)
    local WindowName = options.Name or "SGX UI"
    
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SGX_Fluent_v14"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = game.CoreGui or game.Players.LocalPlayer:WaitForChild("PlayerGui")
    
    -- Intro Title Label
    local IntroLabel = Instance.new("TextLabel")
    IntroLabel.Size = UDim2.new(0, 520, 0, 50)
    IntroLabel.Position = UDim2.new(0.5, -600, 0.5, -25)
    IntroLabel.BackgroundTransparency = 1
    IntroLabel.Text = WindowName
    IntroLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    IntroLabel.Font = Enum.Font.GothamBold
    IntroLabel.TextSize = 25
    IntroLabel.Parent = ScreenGui

    -- Main UI Frame
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 520, 0, 0)
    MainFrame.Position = UDim2.new(0.5, -260, 0.5, -170)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Visible = false
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

    -- Sidebar (Left)
    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 140, 1, -50)
    Sidebar.Position = UDim2.new(0, 10, 0, 45)
    Sidebar.BackgroundTransparency = 1
    Sidebar.Parent = MainFrame
    Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 5)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -20, 0, 30)
    Title.Position = UDim2.new(0, 15, 0, 10)
    Title.BackgroundTransparency = 1
    Title.Text = WindowName
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 15
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = MainFrame

    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -170, 1, -60)
    Container.Position = UDim2.new(0, 160, 0, 50)
    Container.BackgroundTransparency = 1
    Container.Parent = MainFrame

    -- INTRO ANIMATION
    task.spawn(function()
        TS:Create(IntroLabel, TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, -260, 0.5, -25)}):Play()
        task.wait(0.9)
        local spaced = ""
        for i = 1, #WindowName do spaced = spaced .. string.sub(WindowName, i, i) .. " " end
        IntroLabel.Text = spaced:sub(1, -2)
        task.wait(0.8)
        TS:Create(IntroLabel, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        MainFrame.Visible = true
        TS:Create(MainFrame, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 520, 0, 340)}):Play()
    end)

    local Window = { CurrentTab = nil }

    function Window:CreateTab(tabName)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 32)
        TabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = "  " .. tabName
        TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        TabBtn.Font = Enum.Font.Gotham
        TabBtn.TextSize = 13
        TabBtn.TextXAlignment = Enum.TextXAlignment.Left
        TabBtn.Parent = Sidebar
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        local Page = Instance.new("ScrollingFrame")
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Page.Parent = Container
        local Layout = Instance.new("UIListLayout", Page)
        Layout.Padding = UDim.new(0, 8)

        if not Window.CurrentTab then
            Window.CurrentTab = Page
            Page.Visible = true
            TabBtn.TextColor3 = Color3.fromRGB(160, 100, 255)
        end

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then TS:Create(v, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(150, 150, 150)}):Play() end end
            Page.Visible = true
            TS:Create(TabBtn, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(160, 100, 255)}):Play()
        end)

        local TabElements = {}

        -- BUTTON
        function TabElements:CreateButton(name, callback)
            local Button = Instance.new("TextButton")
            Button.Size = UDim2.new(1, -10, 0, 38)
            Button.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            Button.Text = "     " .. name
            Button.TextColor3 = Color3.fromRGB(230, 230, 230)
            Button.Font = Enum.Font.Gotham
            Button.TextSize = 13
            Button.TextXAlignment = Enum.TextXAlignment.Left
            Button.Parent = Page
            Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 6)
            
            Button.MouseButton1Down:Connect(function()
                TS:Create(Button, TweenInfo.new(0.1), {Size = UDim2.new(1, -15, 0, 34)}):Play()
            end)
            Button.MouseButton1Up:Connect(function()
                TS:Create(Button, TweenInfo.new(0.1), {Size = UDim2.new(1, -10, 0, 38)}):Play()
                pcall(callback)
            end)
        end

        -- TOGGLE (With Circle Switch)
        function TabElements:CreateToggle(name, callback)
            local ToggleBtn = Instance.new("TextButton")
            ToggleBtn.Size = UDim2.new(1, -10, 0, 38)
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            ToggleBtn.Text = "     " .. name
            ToggleBtn.TextColor3 = Color3.fromRGB(230, 230, 230)
            ToggleBtn.Font = Enum.Font.Gotham
            ToggleBtn.TextSize = 13
            ToggleBtn.TextXAlignment = Enum.TextXAlignment.Left
            ToggleBtn.Parent = Page
            Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 6)

            local Track = Instance.new("Frame")
            Track.Size = UDim2.new(0, 34, 0, 18)
            Track.Position = UDim2.new(1, -44, 0.5, -9)
            Track.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            Track.Parent = ToggleBtn
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Circle = Instance.new("Frame")
            Circle.Size = UDim2.new(0, 12, 0, 12)
            Circle.Position = UDim2.new(0, 3, 0.5, -6)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Circle.Parent = Track
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            local state = false
            ToggleBtn.MouseButton1Click:Connect(function()
                state = not state
                TS:Create(Track, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(160, 100, 255) or Color3.fromRGB(45, 45, 45)}):Play()
                TS:Create(Circle, TweenInfo.new(0.2), {Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)}):Play()
                pcall(callback, state)
            end)
        end

        -- SLIDER (Fixed logic)
        function TabElements:CreateSlider(name, min, max, callback)
            local SliderFrame = Instance.new("Frame")
            SliderFrame.Size = UDim2.new(1, -10, 0, 45)
            SliderFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            SliderFrame.Parent = Page
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 6)

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, -20, 0, 20)
            Label.Position = UDim2.new(0, 15, 0, 5)
            Label.BackgroundTransparency = 1
            Label.Text = name .. " : " .. min
            Label.TextColor3 = Color3.fromRGB(200, 200, 200)
            Label.Font = Enum.Font.Gotham
            Label.TextSize = 12
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = SliderFrame

            local Bar = Instance.new("Frame")
            Bar.Size = UDim2.new(1, -30, 0, 4)
            Bar.Position = UDim2.new(0, 15, 1, -12)
            Bar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            Bar.Parent = SliderFrame
            Instance.new("UICorner", Bar)

            local Fill = Instance.new("Frame")
            Fill.Size = UDim2.new(0, 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(160, 100, 255)
            Fill.Parent = Bar
            Instance.new("UICorner", Fill)

            local function Move(input)
                local pos = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                TS:Create(Fill, TweenInfo.new(0.1), {Size = UDim2.new(pos, 0, 1, 0)}):Play()
                local val = math.floor(min + ((max - min) * pos))
                Label.Text = name .. " : " .. val
                pcall(callback, val)
            end

            local dragging = false
            SliderFrame.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
            UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
            UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then Move(i) end end)
        end

        -- DROPDOWN (Expandable List)
        function TabElements:CreateDropdown(name, list, callback)
            local Dropdown = Instance.new("Frame")
            Dropdown.Size = UDim2.new(1, -10, 0, 38)
            Dropdown.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            Dropdown.ClipsDescendants = true
            Dropdown.Parent = Page
            Instance.new("UICorner", Dropdown).CornerRadius = UDim.new(0, 6)

            local MainBtn = Instance.new("TextButton")
            MainBtn.Size = UDim2.new(1, 0, 0, 38)
            MainBtn.BackgroundTransparency = 1
            MainBtn.Text = "     " .. name .. "  ▼"
            MainBtn.TextColor3 = Color3.fromRGB(230, 230, 230)
            MainBtn.Font = Enum.Font.Gotham
            MainBtn.TextSize = 13
            MainBtn.TextXAlignment = Enum.TextXAlignment.Left
            MainBtn.Parent = Dropdown

            local expanded = false
            MainBtn.MouseButton1Click:Connect(function()
                expanded = not expanded
                TS:Create(Dropdown, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = expanded and UDim2.new(1, -10, 0, 38 + (#list * 32)) or UDim2.new(1, -10, 0, 38)}):Play()
            end)

            for i, v in ipairs(list) do
                local Opt = Instance.new("TextButton")
                Opt.Size = UDim2.new(1, 0, 0, 30)
                Opt.Position = UDim2.new(0, 0, 0, 38 + ((i-1) * 32))
                Opt.BackgroundTransparency = 1
                Opt.Text = v
                Opt.TextColor3 = Color3.fromRGB(150, 150, 150)
                Opt.Font = Enum.Font.Gotham
                Opt.Parent = Dropdown
                Opt.MouseButton1Click:Connect(function()
                    MainBtn.Text = "     " .. name .. " : " .. v
                    expanded = false
                    TS:Create(Dropdown, TweenInfo.new(0.3), {Size = UDim2.new(1, -10, 0, 38)}):Play()
                    pcall(callback, v)
                end)
            end
        end

        return TabElements
    end

    return Window
end

return Library
