local Library = {}
local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")
local LocalPlayer = game:GetService("Players").LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- Theme Table
local Themes = {
    ["default"] = Color3.fromRGB(15, 15, 15),
    ["blue"] = Color3.fromRGB(0, 20, 50),
    ["red"] = Color3.fromRGB(50, 0, 0),
    ["purple"] = Color3.fromRGB(35, 0, 60),
    ["amethyst"] = Color3.fromRGB(60, 0, 100)
}

function Library:CreateWindow(options)
    local WindowName = options.Name or "SGX UI"
    local ThemeColor = Themes[options.Theme or "default"] or Themes["default"]
    
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SGX_Final_v14"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = game.CoreGui or LocalPlayer:WaitForChild("PlayerGui")
    
    -- Main UI Frame
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 520, 0, 340)
    MainFrame.Position = UDim2.new(0.5, -260, 0.5, -170)
    MainFrame.BackgroundColor3 = ThemeColor
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Visible = false
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

    -- Improved Dragging Logic
    local function MakeDraggable(frame)
        local dragToggle, dragStart, startPos
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragToggle = true dragStart = input.Position startPos = frame.Position
                input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragToggle = false end end)
            end
        end)
        UIS.InputChanged:Connect(function(input)
            if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end
    MakeDraggable(MainFrame)

    -- Sidebar (Left)
    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 140, 1, -50)
    Sidebar.Position = UDim2.new(0, 10, 0, 45)
    Sidebar.BackgroundTransparency = 1
    Sidebar.Parent = MainFrame
    Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 5)

    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -170, 1, -60)
    Container.Position = UDim2.new(0, 160, 0, 50)
    Container.BackgroundTransparency = 1
    Container.Parent = MainFrame

    -- INTRO LOGIC (E X A M P L E)
    local IntroLabel = Instance.new("TextLabel")
    IntroLabel.Size = UDim2.new(0, 520, 0, 50)
    IntroLabel.Position = UDim2.new(0.5, -600, 0.5, -25)
    IntroLabel.BackgroundTransparency = 1
    IntroLabel.Text = WindowName
    IntroLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    IntroLabel.Font = Enum.Font.GothamBold
    IntroLabel.TextSize = 25
    IntroLabel.Parent = ScreenGui

    task.spawn(function()
        TS:Create(IntroLabel, TweenInfo.new(0.8, Enum.EasingStyle.Quart), {Position = UDim2.new(0.5, -260, 0.5, -25)}):Play()
        task.wait(0.9)
        local s = "" for i=1,#WindowName do s=s..string.sub(WindowName,i,i).." " end
        IntroLabel.Text = s:sub(1,-2)
        task.wait(0.8)
        TS:Create(IntroLabel, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        MainFrame.Visible = true
        TS:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Size = UDim2.new(0, 520, 0, 340)}):Play()
    end)

    local Window = { CurrentTab = nil }

    -- Create Toggle UI Button
    function Window:CreateToggleUI(cfg)
        local TBtn = Instance.new("TextButton")
        TBtn.Size = UDim2.new(0, 50, 0, 50)
        TBtn.Position = UDim2.new(0.1, 0, 0.1, 0)
        TBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        TBtn.Text = cfg.name or ""
        TBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        TBtn.Parent = ScreenGui
        Instance.new("UICorner", TBtn).CornerRadius = UDim.new(1, 0)
        MakeDraggable(TBtn)

        if cfg.image and cfg.image ~= "" then
            local Img = Instance.new("ImageLabel")
            Img.Size = UDim2.new(0.7, 0, 0.7, 0)
            Img.Position = UDim2.new(0.15, 0, 0.15, 0)
            Img.Image = cfg.image
            Img.BackgroundTransparency = 1
            Img.Parent = TBtn
        end

        TBtn.MouseButton1Click:Connect(function()
            MainFrame.Visible = not MainFrame.Visible
        end)
    end

    function Window:CreateTab(tabName)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 32)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = "  " .. tabName
        TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        TabBtn.Font = Enum.Font.Gotham
        TabBtn.TextXAlignment = Enum.TextXAlignment.Left
        TabBtn.Parent = Sidebar
        
        local Page = Instance.new("ScrollingFrame")
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Page.Parent = Container
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)

        if not Window.CurrentTab then
            Window.CurrentTab = Page
            Page.Visible = true
            TabBtn.TextColor3 = Color3.fromRGB(160, 100, 255)
        end

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Color3.fromRGB(150, 150, 150) end end
            Page.Visible = true
            TabBtn.TextColor3 = Color3.fromRGB(160, 100, 255)
        end)

        local Elements = {}

        function Elements:CreateButton(name, cb)
            local B = Instance.new("TextButton")
            B.Size = UDim2.new(1, -10, 0, 38)
            B.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            B.Text = "     " .. name
            B.TextColor3 = Color3.fromRGB(230, 230, 230)
            B.TextXAlignment = Enum.TextXAlignment.Left
            B.Parent = Page
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 6)
            B.MouseButton1Click:Connect(cb)
        end

        function Elements:CreateToggle(name, cb)
            local T = Instance.new("TextButton")
            T.Size = UDim2.new(1, -10, 0, 38)
            T.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            T.Text = "     " .. name
            T.TextColor3 = Color3.fromRGB(230, 230, 230)
            T.TextXAlignment = Enum.TextXAlignment.Left
            T.Parent = Page
            Instance.new("UICorner", T).CornerRadius = UDim.new(0, 6)

            local Track = Instance.new("Frame")
            Track.Size = UDim2.new(0, 34, 0, 18)
            Track.Position = UDim2.new(1, -44, 0.5, -9)
            Track.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            Track.Parent = T
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Circle = Instance.new("Frame")
            Circle.Size = UDim2.new(0, 12, 0, 12)
            Circle.Position = UDim2.new(0, 3, 0.5, -6)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Circle.Parent = Track
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            local s = false
            T.MouseButton1Click:Connect(function()
                s = not s
                TS:Create(Track, TweenInfo.new(0.2), {BackgroundColor3 = s and Color3.fromRGB(160, 100, 255) or Color3.fromRGB(45, 45, 45)}):Play()
                TS:Create(Circle, TweenInfo.new(0.2), {Position = s and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)}):Play()
                cb(s)
            end)
        end

        function Elements:CreateSlider(name, min, max, cb)
            local SFrame = Instance.new("Frame")
            SFrame.Size = UDim2.new(1, -10, 0, 45)
            SFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            SFrame.Parent = Page
            Instance.new("UICorner", SFrame).CornerRadius = UDim.new(0, 6)

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, 0, 0, 20)
            Label.Position = UDim2.new(0, 15, 0, 5)
            Label.BackgroundTransparency = 1
            Label.Text = name .. " : " .. min
            Label.TextColor3 = Color3.fromRGB(200, 200, 200)
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = SFrame

            local Bar = Instance.new("Frame")
            Bar.Size = UDim2.new(1, -30, 0, 6)
            Bar.Position = UDim2.new(0, 15, 1, -12)
            Bar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            Bar.Parent = SFrame
            Instance.new("UICorner", Bar)

            local Fill = Instance.new("Frame")
            Fill.Size = UDim2.new(0, 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(160, 100, 255)
            Fill.Parent = Bar
            Instance.new("UICorner", Fill)

            local dragging = false
            local function Update()
                local move = math.clamp((UIS:GetMouseLocation().X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                Fill.Size = UDim2.new(move, 0, 1, 0)
                local val = math.floor(min + ((max - min) * move))
                Label.Text = name .. " : " .. val
                cb(val)
            end

            SFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true Update()
                end
            end)
            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UIS.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    Update()
                end
            end)
        end

        function Elements:CreateDropdown(name, list, cb)
            local D = Instance.new("Frame")
            D.Size = UDim2.new(1, -10, 0, 38)
            D.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            D.ClipsDescendants = true
            D.Parent = Page
            Instance.new("UICorner", D).CornerRadius = UDim.new(0, 6)

            local Main = Instance.new("TextButton")
            Main.Size = UDim2.new(1, 0, 0, 38)
            Main.BackgroundTransparency = 1
            Main.Text = "     " .. name .. "  ▼"
            Main.TextColor3 = Color3.fromRGB(230, 230, 230)
            Main.TextXAlignment = Enum.TextXAlignment.Left
            Main.Parent = D

            local exp = false
            Main.MouseButton1Click:Connect(function()
                exp = not exp
                TS:Create(D, TweenInfo.new(0.3), {Size = exp and UDim2.new(1, -10, 0, 38 + (#list * 32)) or UDim2.new(1, -10, 0, 38)}):Play()
            end)

            for i, v in ipairs(list) do
                local O = Instance.new("TextButton")
                O.Size = UDim2.new(1, 0, 0, 30)
                O.Position = UDim2.new(0, 0, 0, 38 + ((i-1)*32))
                O.BackgroundTransparency = 1
                O.Text = v
                O.TextColor3 = Color3.fromRGB(150, 150, 150)
                O.Parent = D
                O.MouseButton1Click:Connect(function()
                    Main.Text = "     " .. name .. " : " .. v
                    exp = false
                    TS:Create(D, TweenInfo.new(0.3), {Size = UDim2.new(1,-10,0,38)}):Play()
                    cb(v)
                end)
            end
        end

        return Elements
    end

    return Window
end

return Library
